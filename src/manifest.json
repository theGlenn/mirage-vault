{
  "manifest_version": 3,
  "name": "AETHER SHROUD",
  "description": "Reversible anonymization for ChatGPT web UI with session-only in-memory masking.",
  "version": "0.1.0",
  "permissions": ["tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AETHER SHROUD",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://chat.mistral.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://chat.mistral.ai/*"
      ],
      "js": ["mistralBridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
