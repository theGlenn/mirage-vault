{
  "name": "mirage-vault-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Mirage Vault — exposes masked vault sessions to LLM services",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start:stdio": "node dist/index-stdio.js",
    "start:sse": "node dist/index-sse.js",
    "package": "tsc && npx @anthropic-ai/mcpb pack . dist/mirage-vault.mcpb"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.7.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "typescript": "~5.6.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  }
}
