{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": [
    "src/shared/**/*.ts",
    "src/background/vault.ts",
    "src/background/state.ts",
    "scripts/demo.ts",
    "tests/**/*.ts"
  ]
}
